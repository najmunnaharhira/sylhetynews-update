rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // News images: public read; authenticated write (admin uploads)
    match /news/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // PhotoCard template images
    match /photocardTemplates/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
