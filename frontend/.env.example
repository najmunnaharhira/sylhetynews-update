# Backend API (use this for full-stack deployment; leave empty to use Firebase only)
VITE_API_URL=https://your-api-domain.com
# Or local: VITE_API_URL=http://localhost:5000

# Public site URL (e.g. https://sylhetynews.com) – used for share links and canonical URLs
VITE_FRONTEND_URL=https://sylhetynews.com
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_ADMIN_EMAILS=your_email@example.com
