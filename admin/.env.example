# Admin users allowed to sign in from the UI.
VITE_ADMIN_EMAILS=admin@gmail.com

# Public API origin for Lovable or any other hosted frontend.
# Example: https://your-backend-domain.com/api
VITE_API_URL=/api

# Local Vite dev proxy target. Keep this only for local development.
VITE_API_PROXY_TARGET=http://127.0.0.1:5000

# In Lovable preview/edit mode, leave this false to avoid aggressive service worker caching.
# Turn it on for the published admin app when you want installable PWA behavior.
VITE_ENABLE_PWA=false

# Optional: open local browser automatically when running npm run dev.
VITE_OPEN_BROWSER=false
