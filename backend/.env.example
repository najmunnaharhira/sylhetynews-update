ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@123
# Optional: use bcrypt hash instead of plain password (generate with: node -e "console.log(require('bcryptjs').hashSync('YourPassword', 10))")
# ADMIN_PASSWORD_HASH=$2a$10$...
JWT_SECRET=your-super-secret-jwt-key-change-in-production
PORT=5000
NODE_ENV=development
FRONTEND_URL=https://sylhetynews.com
# Public URL of this API (for absolute image URLs in uploads). e.g. https://api.sylhetynews.com
API_PUBLIC_URL=

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sylhety-news

# Firebase (Admin)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=sylhetly-news.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=sylhetly-news
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=sylhetly-news.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id
NEXT_PUBLIC_ADMIN_EMAILS=admin@gmail.com
