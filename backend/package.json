  "type": "module",
  "description": "Backend API for Sylhetly News",
  "main": "src/server.ts",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "seed": "tsx src/seed.ts",
    "test": "jest"
  },
  "keywords": [
    "news",
    "cms",
    "api"
  ],
  "author": "",
  "license": "ISC",
